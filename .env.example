# Example environment variables for DFXN_MERN
# Copy this to a local `.env` and fill with real values (never commit secrets).

# Server
PORT=5000
NODE_ENV=development
CLIENT_URLS=http://localhost:5173
MAX_IMAGE_UPLOAD_BYTES=8388608
ADMIN_AUDIT_LOG_RETENTION_DAYS=365

# MongoDB (replace with your connection string)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/DFXN_DB

# Redis (Upstash or other)
UPSTASH_REDIS_URL=rediss://<user>:<password>@<host>:6379

# JWT secrets
ACCESS_TOKEN_SECRET=change_this_to_a_random_long_secret
REFRESH_TOKEN_SECRET=change_this_to_a_random_long_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_key
CLOUDINARY_API_SECRET_KEY=your_secret

# SMTP (mailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_SECURE=false
SMTP_PASSWORD=example_password
SMTP_FROM="DFXN Styles team <you@example.com>"
CONTACT_NOTIFY_TO=notify@example.com

# Chapa (payments)
CHAPA_SECRET_KEY=CHAPA_TEST_KEY
CHAPA_WEBHOOK_SECRET=your_chapa_webhook_secret
CHAPA_SIGNATURE_HEADER=x-chapa-signature
CHAPA_WEBHOOK_FIRST=true
CHAPA_RETURN_URL=http://localhost:5173/payment-result
CHAPA_CALLBACK_URL=https://your-callback.example.com/api/orders/payment/callback
CHAPA_DEFAULT_EMAIL=chapa.test@gmail.com
F_CHAPA_VERIFY_ON_RETURN=false

# Optional: feature flags / other settings
MASTER_EMAIL=master@email.com
MASTER_PASSWORD=change_this_master_password
MASTER_NAME=Master

# Notes:
# - Never put real credentials in the repository. Use environment-specific secret stores.
# - In production set NODE_ENV=production and ensure secure secrets for all keys above.
# - CHAPA_DEFAULT_EMAIL is only used outside production; production online payments require a valid customer email.
